THE VERDANT PAGE — PROJECT SUMMARY
====================================
Nature Writing Platform | Full-Stack Web Application
Built on: React + Vite (frontend) · Express (API) · PostgreSQL (database)
Monorepo managed with pnpm workspaces


━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
1. PROJECT OVERVIEW
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

A professional portfolio and publishing site for a nature writer covering
animals, plants, oceans, and conservation. The platform supports article
publishing, species profiles, a portfolio of press clips, service offerings,
contact/newsletter capture, and a full REST API backend.

Brand palette: Forest green (#2D5016) + Ivory (#F5F0E8)
Typography: Fraunces (serif headings) + Plus Jakarta Sans (body)
Animations: Framer Motion throughout


━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
2. REPOSITORY STRUCTURE
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

/
├── artifacts/
│   ├── nature-platform/        React + Vite frontend (served at /)
│   └── api-server/             Express REST API (served at /api)
├── lib/
│   ├── db/                     Drizzle ORM schema + migrations
│   ├── api-spec/               OpenAPI 3.0 spec (openapi.yaml)
│   ├── api-client-react/       Orval-generated React Query hooks
│   └── api-zod/                Orval-generated Zod validators
└── scripts/                    Shared utility scripts


━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
3. DATABASE SCHEMA  (lib/db/src/schema/)
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

TABLE: articles
  id, title, slug, excerpt, content, image_url, image_alt
  category_id (FK → categories), category (text cache)
  author, read_time, word_count, view_count
  status (published | draft | archived)
  seo_title, seo_description
  published_at, created_at, updated_at

TABLE: categories
  id, name, slug, description, color, icon, created_at
  SEEDED: Animals · Oceans · Plants · Conservation · Field Notes · Human & Nature

TABLE: tags
  id, name, slug, created_at
  SEEDED: 12 tags (coral reef, climate change, endangered species, rewilding,
           fungi, ocean health, behavior, field research, botany, marine biology,
           predators, ecosystems)

TABLE: article_tags  (many-to-many join)
  article_id (FK), tag_id (FK)

TABLE: species
  id, common_name, scientific_name, slug, kingdom, species_class
  order_name, family, conservation_status (IUCN codes)
  habitat, geographic_range, diet, description
  fun_facts (JSON array), image_url, iucn_url, article_id (FK)
  created_at
  SEEDED: African Elephant · Blue Whale · Mimic Octopus · Corpse Flower · Snow Leopard

TABLE: portfolio_clips
  id, title, publication, url, date, category, description
  word_count, image_url, featured, created_at
  SEEDED: 7 portfolio clips across major publications

TABLE: contact_messages
  id, name, email, subject, message, created_at

TABLE: newsletter_subscribers
  id, email, name, status (active | unsubscribed), subscribed_at


━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
4. REST API  (artifacts/api-server — served at /api)
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

ARTICLES
  GET    /api/articles              List (filter: status, categoryId, tag, search, limit, offset)
  POST   /api/articles              Create article
  GET    /api/articles/:slug        Get by slug (auto-increments viewCount)
  PUT    /api/articles/:slug        Update article
  DELETE /api/articles/:slug        Delete article
  POST   /api/articles/:id/tags     Attach tags to article

CATEGORIES
  GET    /api/categories            List all categories
  POST   /api/categories            Create category
  GET    /api/categories/:slug      Get by slug
  PUT    /api/categories/:slug      Update
  DELETE /api/categories/:slug      Delete

TAGS
  GET    /api/tags                  List all tags
  POST   /api/tags                  Create tag
  GET    /api/tags/:slug            Get by slug
  PUT    /api/tags/:slug            Update
  DELETE /api/tags/:slug            Delete

SPECIES
  GET    /api/species               List (filter: kingdom, conservationStatus, search)
  POST   /api/species               Create species profile
  GET    /api/species/:slug         Get species by slug
  PUT    /api/species/:slug         Update
  DELETE /api/species/:slug         Delete

PORTFOLIO
  GET    /api/portfolio             List clips (filter: featured)
  POST   /api/portfolio             Create clip
  GET    /api/portfolio/:id         Get by id
  PUT    /api/portfolio/:id         Update
  DELETE /api/portfolio/:id         Delete

CONTACT
  POST   /api/contact               Submit contact message
  GET    /api/contact               List all messages (admin)

NEWSLETTER
  POST   /api/newsletter/subscribe  Subscribe email
  POST   /api/newsletter/unsubscribe Unsubscribe email
  GET    /api/newsletter            List subscribers (admin)

HEALTH
  GET    /api/healthz               Health check


━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
5. CODE GENERATION PIPELINE
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

Source of truth: lib/api-spec/openapi.yaml

Running `pnpm --filter @workspace/api-spec run codegen` generates:
  • lib/api-client-react/src/generated/api.ts       — React Query hooks
  • lib/api-client-react/src/generated/api.schemas.ts — TypeScript types
  • lib/api-zod/src/generated/api.ts               — Zod validation schemas

Frontend consumes typed hooks like:
  useListArticles(params)   useGetArticle(slug)
  useListSpecies(params)    useListCategories()   etc.


━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
6. FRONTEND PAGES  (artifacts/nature-platform/src/pages/)
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

Route         File                  Description
/             Home.tsx              Hero, featured articles, stats, newsletter CTA
/articles     Articles.tsx          Article grid with live category filter + search
/articles/:s  ArticleReader.tsx     Full article with view count, tags, share buttons
/species      Species.tsx           Species grid with kingdom + IUCN status filters
/species/:s   SpeciesProfile.tsx    Full species profile: facts, conservation, fun facts
/portfolio    Portfolio.tsx         Press clips / published work
/services     Services.tsx          Writing services offered
/about        About.tsx             Author bio page
/contact      Contact.tsx           Contact form (posts to API)
/newsletter   Newsletter.tsx        Newsletter signup (posts to API)


